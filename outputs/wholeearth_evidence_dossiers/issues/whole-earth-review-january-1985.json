    },
    {
      "line": 41,
      "text": "Jim Ludtke"
    },
    {
      "line": 44,
      "text": "Self-confessed computer junkie"
    },
    {
      "line": 45,
      "text": "Birrell Walsh had his wife hide"
    },
    {
      "line": 46,
      "text": "his telecommunication modem"
    },
    {
      "line": 47,
      "text": "to save money. Away from his"
